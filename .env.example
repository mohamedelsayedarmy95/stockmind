# ── Server ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=stockmind
DB_PASSWORD=stockmind123
DB_DATABASE=stockmind
# Set to true for hosted Postgres (e.g. Neon) — required, their endpoints reject
# plaintext connections. Leave false for local docker-compose Postgres.
DB_SSL=false

# ── JWT ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-256bit
JWT_REFRESH_SECRET=change-me-refresh-secret-256bit
# Distinct secret for short-lived 2FA "temp tokens" (falls back to a derived
# value if unset, but set it explicitly in production).
JWT_2FA_SECRET=change-me-2fa-secret-256bit
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Data-at-rest encryption (Phase 4) ───────────────
# AES-256-GCM master key for encrypted columns (2FA secrets, product cost price).
# Leave EMPTY in dev (columns store plaintext). In prod, inject a strong secret
# managed outside the repo; rotating it makes previously-encrypted values unread.
DB_ENCRYPTION_KEY=

# ── Network allowlist (Phase 4, on-premise) ─────────
# Comma-separated exact client IPs allowed to reach the API. Empty = allow all.
ALLOWED_IPS=

# ── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── CORS ────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:4200

# ── File Storage ────────────────────────────────────
# One of: local | s3 | cloudinary
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
UPLOAD_PUBLIC_PATH=/uploads

# S3 (used when STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_CDN_BASE=

# Cloudinary (used when STORAGE_DRIVER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Hugging Face AI ──────────────────────────────────
# Get a free token at https://huggingface.co/settings/tokens (read access)
HF_API_KEY=

# ── SAML 2.0 SSO (Phase 4) ──────────────────────────
# Set SAML_ENABLED=true to register the SAML module. Leave false/unset for
# installations that use only password + 2FA (the default).
SAML_ENABLED=false

# AUTH_PROVIDER controls the /auth/login behaviour:
#   local  (default) — password + optional 2FA; SAML is available in parallel.
#   saml   — /auth/login rejects local passwords and redirects to /auth/saml/login.
AUTH_PROVIDER=local

# Values below are required only when SAML_ENABLED=true.
SAML_ENTRY_POINT=https://idp.example.com/saml/sso
SAML_ISSUER=https://api.stockmind.io
SAML_CALLBACK_URL=https://api.stockmind.io/api/v1/auth/saml/callback
# PEM-encoded PUBLIC signing certificate of the IdP (not the private key).
# Paste the full certificate including -----BEGIN CERTIFICATE----- header.
SAML_CERT=

# ── Firebase Admin SDK ───────────────────────────────
# Download service account JSON from Firebase Console → Project Settings → Service accounts
# Paste the individual fields below (do NOT paste the full JSON as a single value)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
