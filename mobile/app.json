{
  "expo": {
    "name": "StockMind",
    "slug": "stockmind",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "stockmind",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "backgroundColor": "#0A0E17",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.stockmind.app",
      "infoPlist": {
        "NSCameraUsageDescription": "StockMind uses the camera to scan product barcodes.",
        "NSFaceIDUsageDescription": "StockMind uses Face ID to protect your session and local data."
      }
    },
    "android": {
      "package": "io.stockmind.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0E17"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow StockMind to scan barcodes."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#00D2FF"
        }
      ],
      "expo-secure-store",
      "@react-native-google-signin/google-signin",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "StockMind uses Face ID to protect your session and local data."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://YOUR-BACKEND-URL/api/v1",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "69f63676-f081-4424-8a1f-5c1b6e92931a"
      }
    },
    "owner": "mohamedelsayedarmy95"
  }
}
